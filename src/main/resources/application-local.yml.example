spring:
  datasource:
    url: ${DB_URL:jdbc:postgresql://localhost:5432/orderflow}
    username: ${DB_USERNAME:orderflow}
    password: ${DB_PASSWORD:orderflow}

  data:
    redis:
      host: ${REDIS_HOST:localhost}
      port: ${REDIS_PORT:6379}

  jpa:
    show-sql: true

management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics,env
  endpoint:
    health:
      show-details: always

app:
  security:
    jwt:
      issuer: orderflow
      access-token-ttl: 15m
      refresh-token-ttl: 7d

      # 32 Byte (256 bit) secret
      secret: ${JWT_SECRET:PleaseChangeDevOnlySecretLocally}
